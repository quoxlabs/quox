{
  "name": "@quoxlabs/quox",
  "version": "0.0.1-alpha.3",
  "tasks": {
    "build": "cargo build --release --target x86_64-unknown-linux-gnu",
    "dev": "cargo build --profile dev --target x86_64-unknown-linux-gnu",
    "dev:mac": "cargo build --profile dev --target aarch64-apple-darwin"
  },
  "exports": "./src/mod.ts",
  "imports": {
    "@std/fs": "jsr:@std/fs@^1.0.22",
    "@std/path": "jsr:@std/path@^1.1.4"
  },
  "license": "MIT",
  "publish": {
    "include": [
      "./src/mod.ts",
      "./target/x86_64-unknown-linux-gnu/release/libquox.so"
    ],
    "exclude": [
      "!./target/x86_64-unknown-linux-gnu/release/libquox.so"
    ]
  }
}
