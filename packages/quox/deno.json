{
  "name": "@quoxlabs/quox",
  "version": "0.0.1-alpha.4",
  "tasks": {
    "dev": "cargo build --profile dev",
    "build:lib-darwin-arm64": "cargo build --release --target aarch64-apple-darwin",
    "build:lib-darwin-x64": "cargo build --release --target x86_64-apple-darwin",
    "build:lib-linux-arm64-gnu": "cargo build --release --target aarch64-unknown-linux-gnu",
    "build:lib-linux-x64-gnu": "cargo build --release --target x86_64-unknown-linux-gnu"
  },
  "exports": "./src/mod.ts",
  "imports": {
    "@std/fs": "jsr:@std/fs@^1.0.22",
    "@std/path": "jsr:@std/path@^1.1.4"
  },
  "license": "MIT",
  "publish": {
    "include": [
      "./src/mod.ts"
    ]
  }
}
