{
  "name": "@quoxlabs/quox",
  "version": "0.0.1-alpha.3",
  "exports": "./mod.ts",
  "license": "MIT",
  "tasks": {
    "wasmbuild": "deno run -A jsr:@deno/wasmbuild@0.21.1",
    "build": "deno task wasmbuild --debug --skip-opt",
    "build:prod": "deno task wasmbuild"
  },
  "publish": {
    "include": [
      "./mod.ts",
      "./lib/"
    ]
  },
  "imports": {
    "preact": "npm:preact@^10.29.1",
    "preact-render-to-string": "npm:preact-render-to-string@^6.6.7"
  }
}
