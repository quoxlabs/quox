{
  "tasks": {
    "dev": "cd packages/quox && deno task dev",
    "build": "cd packages/quox && deno task build",
    "ok": "deno fmt --check && deno lint && deno check"
  },
  "fmt": {
    "lineWidth": 120,
    "proseWrap": "never"
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "workspace": ["./packages/quox"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "imports": {
    "preact": "npm:preact@^10.29.0",
    "preact-render-to-string": "npm:preact-render-to-string@^6.6.7"
  }
}
